# Fisherd profile for Huanjing's GW/RPA runs.
# Runtime rule: source ~/.bashrc explicitly, then prefer the ghj_main Python environment.

OH_MY_LIBRPA_SERVER_NAME=fisherd-ghj
OH_MY_LIBRPA_BASHRC_SOURCE=/home/ghj/.bashrc
OH_MY_LIBRPA_CONDA_ENV=ghj_main
OH_MY_LIBRPA_PYTHON3_EXEC=/home/ghj/.conda/envs/ghj_main/bin/python
OH_MY_LIBRPA_ABACUS_EXEC=/home/ghj/app/abacus/merge_test/abacus-develop/build/abacus_3p
OH_MY_LIBRPA_LIBRPA_EXEC=/home/ghj/app/LibRPA/build/chi0_main.exe
OH_MY_LIBRPA_MPI_LAUNCHER=mpirun
OH_MY_LIBRPA_MPI_LAUNCHER_CMD=mpirun
OH_MY_LIBRPA_DEFAULT_MPI_RANKS=4
OH_MY_LIBRPA_DEFAULT_PYATB_MPI_RANKS=1
OH_MY_LIBRPA_DEFAULT_OMP_THREADS=32
